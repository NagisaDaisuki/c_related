     1	// 复印一个结构体数组
     2	#include "player.h"
     3	#include <stdio.h>
     4	#include <stdlib.h>
     5	
     6	int main() {
     7	  // 准备要在内存中写出的数据
     8	  Player team[3] = {
     9	      {101, 50, 99.5},
    10	      {102, 30, 45.0},
    11	      {103, 99, 150.0},
    12	  };
    13	
    14	  // 1. 打开文件 (wb = Write Binary 写 二进制 文件)
    15	  FILE *file = fopen("sava_data.bin", "wb");
    16	  if (file == NULL) {
    17	    perror("文件打开失败");
    18	    return 1;
    19	  }
    20	
    21	  // 2. 核心操作：一键复印内存!
    22	  // 意思是：把 team 数组首地址开始，大小为 sizeof(Player)的数据，写 3 份到 file
    23	  // 中
    24	  size_t written_count = fwrite(team, sizeof(Player), 3, file);
    25	
    26	  // 3. 检查有没有写够（及其良好的工程习惯）
    27	  if (written_count != 3) {
    28	    fprintf(stderr, "警告：只成功写入了 %zu 个 元素！\n", written_count);
    29	  } else {
    30	    printf("成功将 3 个玩家数据写入二进制文件！\n");
    31	  }
    32	
    33	  // 4. 关门
    34	  fclose(file);
    35	
    36	  return EXIT_SUCCESS;
    37	}
