CC = gcc
CFLAGS = -Wall -Wextra -g -std=c11 -O2

TARGET = hello
SRCS = .

# wildcard 抓取真实文件
C_SRCS = $(wildcard $(SRCS)/*.c)
C_OBJS = $(C_SRCS:.c=.o)

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(C_OBJS)
	$(CC) $(CFLAGS) -o $@ $^

$(SRCS)/%.o: $(SRCS)/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

$(SRCS)/hello.o: $(SRCS)/hello.c $(SRCS)/add.h $(SRCS)/sub.h $(SRCS)/sum.h $(SRCS)/mul.h $(SRCS)/head.h
$(SRCS)/add.o: $(SRCS)/add.c $(SRCS)/add.h $(SRCS)/head.h
$(SRCS)/sub.o: $(SRCS)/sub.c $(SRCS)/sub.h $(SRCS)/head.h
$(SRCS)/mul.o: $(SRCS)/mul.c $(SRCS)/mul.h $(SRCS)/head.h
$(SRCS)/sum.o: $(SRCS)/sum.c $(SRCS)/sum.h $(SRCS)/head.h

clean:
	rm -f $(TARGET) $(SRCS)/*.o
